{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Missing filename returns 400",
      "method": "POST",
      "path": "/",
      "body": {},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Returns presigned URL",
      "method": "POST",
      "path": "/",
      "body": {"filename": "test.mp3"},
      "expectedStatus": 200,
      "expectedBody": {"upload_url": "string", "cdn_url": "string"},
      "bodyMatcher": "partial"
    }
  ]
}
